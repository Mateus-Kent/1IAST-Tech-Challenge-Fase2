layers/bronze/*
!layers/bronze/.gitkeep
layers/silver/*
!layers/silver/.gitkeep
layers/gold/*
!layers/gold/.gitkeep

# Amostras locais temporárias
data/samples/*
!data/samples/.gitkeep

# ── Variáveis de ambiente e segredos ──────────────────────────────
.env
.env.local
*.env

# ── IDEs ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Sistema operacional ───────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs e relatórios ─────────────────────────────────────────────
*.log
logs/
great_expectations/uncommitted/

# ── Terraform ─────────────────────────────────────────────────────
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/*.tfvars
