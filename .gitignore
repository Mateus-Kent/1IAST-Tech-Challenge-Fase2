# ── Ambiente Python ───────────────────────────────────────────────
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
pip-log.txt

# ── Jupyter ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.nbconvert/

# ── Dados gerados (camadas do pipeline) ───────────────────────────
